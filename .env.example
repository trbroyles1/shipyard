# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# GitLab OAuth application credentials (Auth.js v5 convention)
AUTH_GITLAB_ID=
AUTH_GITLAB_SECRET=

# GitLab instance URL (no trailing slash)
GITLAB_URL=https://gitlab.com

# Top-level GitLab group ID to monitor
GITLAB_GROUP_ID=

# Logging level: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO
